# Build the Vite frontend, then serve it via a tiny nginx
# Image: ~25 MB after build

FROM node:20-alpine AS builder

WORKDIR /build

# Cache deps
# `npm install` over `npm ci` because the lockfile drifted away from
# package.json on the main branch. --legacy-peer-deps keeps openapi-typescript@7
# (peer typescript@^5) compatible with our typescript@6.
COPY web/package.json web/package-lock.json* ./
RUN npm install --no-audit --no-fund --legacy-peer-deps

# Source
COPY web/ ./

# Build-time env (compiled into the static bundle)
# VITE_API_BASE_URL='' means the frontend uses relative /api paths,
# which Caddy will proxy to the server container.
ARG VITE_API_BASE_URL=""
ARG VITE_SUPABASE_URL=""
ARG VITE_SUPABASE_ANON_KEY=""
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}
ENV VITE_SUPABASE_URL=${VITE_SUPABASE_URL}
ENV VITE_SUPABASE_ANON_KEY=${VITE_SUPABASE_ANON_KEY}

RUN npm run build


# ----- runtime -----
FROM nginx:1.27-alpine

# SPA fallback so /browse, /review, /connect etc. all serve index.html
RUN rm /etc/nginx/conf.d/default.conf
COPY deploy/nginx-spa.conf /etc/nginx/conf.d/default.conf

COPY --from=builder /build/dist /usr/share/nginx/html

EXPOSE 8080
CMD ["nginx", "-g", "daemon off;"]
