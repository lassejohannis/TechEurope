# ─── Production .env template for chickentendr.club ────────────────────────
# Copy to repo-root `.env`, fill values, then `docker compose up -d --build`.
# This file is read by docker-compose.yml (env_file: .env) and substituted
# into both the server container's process env AND the web build args.

# Network
API_HOST=0.0.0.0
API_PORT=8000

# Supabase (Postgres + Realtime)
SUPABASE_URL=https://ogfrqdchizywnnchelep.supabase.co
SUPABASE_PUBLISHABLE_KEY=<your_supabase_publishable_key>
SUPABASE_SECRET_KEY=<your_supabase_secret_key>
SUPABASE_JWT_SECRET=<your_supabase_jwt_secret>
POSTGRES_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Gemini
GEMINI_API_KEY=<your_gemini_key>
GEMINI_MODEL=gemini-2.5-flash

# Pioneer (optional — Tier 3.5 cascade)
PIONEER_API_KEY=<your_pioneer_key>
PIONEER_MODEL_ID=<your_pioneer_model_id>

# Tavily (optional — entity enrichment)
TAVILY_API_KEY=<your_tavily_key>

# Neo4j Aura (optional — leave NEO4J_URI empty to disable projection worker)
NEO4J_URI=neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_USERNAME=<instance-id>
NEO4J_PASSWORD=<your_aura_password>
NEO4J_DATABASE=<instance-id>

# API auth posture
# false = require Bearer token on /api/* (recommended for production)
# true  = open access (only for live demos!)
API_AUTH_DISABLED=false

# HMAC pepper (do not regenerate — invalidates all existing webhook secrets)
WEBHOOK_SECRET_PEPPER=<your_hmac_pepper>

# slowapi quotas
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTHENTICATED=600/minute
