# FastAPI
API_HOST=127.0.0.1
API_PORT=8000

# Supabase — fill from project Settings -> API Keys
# Project ref is in the repo's .mcp.json (iaxcvofompnmzxxdymmm).
# New key naming: publishable replaces anon, secret replaces service_role.
# Tokens look like sb_publishable_... and sb_secret_...
SUPABASE_URL=https://iaxcvofompnmzxxdymmm.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Google DeepMind (Gemini) — partner tech
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp

# Neo4j Aura (read-only projection — WS-5)
# Leave NEO4J_URI empty to disable the projection worker.
# These are the names Aura ships in its downloadable credentials file.
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
